{
  "name": "@medSphere/clinical-charting",
  "version": "1.0.0",
  "description": "Clinical Charting Service for MedSphere EHR System",
  "main": "dist/main.js",
  "scripts": {
    "start": "node dist/main.js",
    "dev": "nest start --watch",
    "build": "nest build",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./test/jest-e2e.json"
  },
  "dependencies": {
    "@nestjs/common": "^9.0.0",
    "@nestjs/core": "^9.0.0",
    "@nestjs/platform-express": "^9.0.0",
    "@nestjs/typeorm": "^9.0.0",
    "@nestjs/config": "^2.0.0",
    "@nestjs/jwt": "^9.0.0",
    "@nestjs/passport": "^9.0.0",
    "passport": "^0.6.0",
    "passport-jwt": "^4.0.0",
    "passport-local": "^1.0.0",
    "typeorm": "^0.3.0",
    "pg": "^8.8.0",
    "class-validator": "^0.13.0",
    "class-transformer": "^0.5.0",
    "bcryptjs": "^2.4.3",
    "@nestjs/swagger": "^6.0.0",
    "swagger-ui-express": "^4.0.0"
  },
  "devDependencies": {
    "@nestjs/cli": "^9.0.0",
    "@nestjs/schematics": "^9.0.0",
    "@nestjs/testing": "^9.0.0",
    "@types/express": "^4.17.0",
    "@types/jest": "^28.0.0",
    "@types/node": "^16.0.0",
    "typescript": "^4.7.0",
    "jest": "^28.0.0",
    "ts-jest": "^28.0.0",
    "supertest": "^6.0.0",
    "rimraf": "^3.0.0",
    "prettier": "^2.0.0",
    "eslint": "^8.0.0"
  },
  "jest": {
    "moduleFileExtensions": ["js", "json", "ts"],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": ["**/*.(t|s)"],
    "testEnvironment": "node",
    "roots": ["<rootDir>/src"],
    "testMatch": ["**/?(*/)+(*.)ts"],
    "snapshotFormat": {
      "escapeString": false,
      "propagateEscape": false
    }
  }
}